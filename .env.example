# Environment Configuration for Playwright Tests
# Copy this file to .env and update with actual credentials

# Test Environment (qa, stg, uat)
TEST_ENV=qa

# QA Environment Credentials
QA_ADMIN_USER=your_qa_admin_username
QA_ADMIN_PASS=your_qa_admin_password

# Staging Environment Credentials
STG_ADMIN_USER=your_stg_admin_username
STG_ADMIN_PASS=your_stg_admin_password

# UAT Environment Credentials
UAT_ADMIN_USER=your_uat_admin_username
UAT_ADMIN_PASS=your_uat_admin_password

# Optional: Database connection for cleanup (if needed)
# DB_CONNECTION_STRING=your_database_connection_string

# Optional: Test data settings
# CLEANUP_AFTER_SUITE=true
# CLEANUP_AFTER_EACH_TEST=false
